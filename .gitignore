```gitignore
# Dependencies
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Build and distribution
build/
dist/
*.egg-info/

# Environment files
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
.coverage
htmlcov/
.coverage.*

# Testing
.pytest_cache/
.mypy_cache/

# Editors
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db
```